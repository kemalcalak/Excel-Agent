# --- OpenAI API ---
# Get your key here: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Google OAuth (for Sheets + Drive access) ---
# No env vars are read for Google auth. Place an OAuth client secret file
# named `credentials.json` (type: "Desktop app") in the project root.
# On first run a browser opens for consent and `token.json` is written;
# subsequent runs reuse that token. Both files are gitignored.