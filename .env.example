# --- OpenAI API ---
# Get your key here: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Google OAuth (for Sheets + Drive access) ---
# These are NOT required if credentials.json is placed in the project root;
# agno reads them from that file automatically. You may still keep them here
# as a fallback.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=
# GOOGLE_REDIRECT_URI=http://localhost
